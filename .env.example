# Porta (Render define automaticamente; local pode usar 3000)
PORT=3000

# Base da API do PagSchool (EXEMPLO)
# Você vai colocar a URL REAL que eles te passaram, tipo:
# https://sistema.pagschool.com.br/prod/api
PAGSCHOOL_BASE_URL=https://sistema.pagschool.com.br/prod/api

# Autenticação: bearer | basic | header
PAGSCHOOL_AUTH_TYPE=bearer

# Se bearer:
PAGSCHOOL_TOKEN=COLE_SEU_TOKEN_AQUI

# Se basic:
PAGSCHOOL_USER=SEU_USUARIO
PAGSCHOOL_PASS=SUA_SENHA

# Se header (caso eles usem algo tipo X-API-KEY):
PAGSCHOOL_HEADER_NAME=X-API-KEY
PAGSCHOOL_HEADER_VALUE=COLE_A_CHAVE_AQUI

# Rotas (AJUSTE conforme a documentação REAL deles)
PAGSCHOOL_FIND_CONTRACT_PATH=/contratos/buscar
PAGSCHOOL_GET_BOLETO_PATH=/boleto/segunda-via

# Opcional: proteger seu webhook com um segredo
WEBHOOK_SHARED_SECRET=UM_SEGREDO_FORTE_AQUI
